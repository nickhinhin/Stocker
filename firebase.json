{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "stocking-eafe1",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/local-functions/fetch-stock-data",
        "function": "fetchStockDataHttp"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
